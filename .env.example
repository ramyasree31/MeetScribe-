# ──────────────────────────────────────────────────────────
# Supabase — create a free project at https://supabase.com
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# ──────────────────────────────────────────────────────────
# Database — copy the connection string from Supabase → Settings → Database
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ──────────────────────────────────────────────────────────
# Kafka (handled by Docker Compose — no changes needed)
# ──────────────────────────────────────────────────────────
KAFKA_BROKERS="localhost:9092"

# ──────────────────────────────────────────────────────────
# Google OAuth2 — create at https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID → Desktop App
# ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ──────────────────────────────────────────────────────────
# AI Services — provide at least ONE key
# Groq  (free):     https://console.groq.com
# Gemini (free):    https://aistudio.google.com/app/apikey
# Anthropic (paid): https://console.anthropic.com
# ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY="your_deepgram_api_key"
ANTHROPIC_API_KEY="placeholder_anthropic_key"
GEMINI_API_KEY="your_gemini_api_key"
GROQ_API_KEY="your_groq_api_key"

# ──────────────────────────────────────────────────────────
# Service URLs (leave as-is for local Docker Compose)
# ──────────────────────────────────────────────────────────
AUDIO_PROCESSOR_URL="ws://localhost:8001"
REDIS_URL="redis://:redispass@localhost:6379"
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:4000"

# ──────────────────────────────────────────────────────────
# Docker (bot-orchestrator)
# ──────────────────────────────────────────────────────────
BOT_WORKER_IMAGE="meetscribe/bot-worker:latest"
DOCKER_NETWORK="meetingbot_default"

# ──────────────────────────────────────────────────────────
# Email — create a free account at https://resend.com
# ──────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
EMAIL_FROM_ADDRESS="noreply@yourdomain.com"
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="your_resend_api_key"
SMTP_SENDER_NAME="MeetScribe"
SMTP_SENDER_EMAIL="onboarding@resend.dev"

# ──────────────────────────────────────────────────────────
# Bot settings
# ──────────────────────────────────────────────────────────
BOT_NAME="AI Notetaker"
BOT_PROFILE_DIR="./profiles"
TOKEN_ENCRYPTION_KEY="generate_a_64_char_hex_string_here"
PUBLIC_API_URL="http://localhost:3000"
